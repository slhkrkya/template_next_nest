# =============================================================================
# Backend .gitignore — NestJS
# =============================================================================

# ---------------------------------------------------------------------------
# Environment / Secrets
# ---------------------------------------------------------------------------
.env
.env.*
!.env.example
!.env.sample

# Certificates & private keys
*.pem
*.key
*.crt
*.cer
*.p12
*.pfx

# ---------------------------------------------------------------------------
# Compiled output
# ---------------------------------------------------------------------------
/dist
/build

# ---------------------------------------------------------------------------
# Dependencies
# ---------------------------------------------------------------------------
/node_modules
/.pnp
.pnp.js

# ---------------------------------------------------------------------------
# Uploads (user-uploaded files must never be committed)
# ---------------------------------------------------------------------------
/uploads/*
!/uploads/.gitkeep

# ---------------------------------------------------------------------------
# Logs
# ---------------------------------------------------------------------------
logs/
*.log
npm-debug.log*
yarn-debug.log*

# ---------------------------------------------------------------------------
# Test & coverage
# ---------------------------------------------------------------------------
/coverage
/.nyc_output

# ---------------------------------------------------------------------------
# IDE
# ---------------------------------------------------------------------------
.idea/
.vscode/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# ---------------------------------------------------------------------------
# Misc
# ---------------------------------------------------------------------------
*.tsbuildinfo
.cache/
