# =============================================================================
# Frontend .gitignore — Next.js
# =============================================================================

# ---------------------------------------------------------------------------
# Environment / Secrets
# ---------------------------------------------------------------------------
.env
.env.*
!.env.example
!.env.sample

# Certificates & private keys
*.pem
*.key
*.crt

# ---------------------------------------------------------------------------
# Dependencies
# ---------------------------------------------------------------------------
/node_modules
/.pnp
.pnp.js

# ---------------------------------------------------------------------------
# Next.js build output
# ---------------------------------------------------------------------------
/.next/
/out/
/build

# ---------------------------------------------------------------------------
# Test & coverage
# ---------------------------------------------------------------------------
/coverage

# ---------------------------------------------------------------------------
# Logs
# ---------------------------------------------------------------------------
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ---------------------------------------------------------------------------
# Vercel / deploy
# ---------------------------------------------------------------------------
.vercel

# ---------------------------------------------------------------------------
# IDE
# ---------------------------------------------------------------------------
.idea/
.vscode/
*.suo
*.sw?

# ---------------------------------------------------------------------------
# Misc
# ---------------------------------------------------------------------------
.DS_Store
*.tsbuildinfo
next-env.d.ts
