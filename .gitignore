# =============================================================================
# Root .gitignore — template_next_nest_js
# =============================================================================

# ---------------------------------------------------------------------------
# Environment / Secrets  ← NEVER commit these
# ---------------------------------------------------------------------------
.env
.env.*
!.env.example
!.env.sample

# Certificates & private keys
*.pem
*.key
*.crt
*.cer
*.p12
*.pfx
*.jks
*.keystore
id_rsa
id_ed25519
*.pub

# Generic secret files
secrets/
*.secret
*.secrets
service-account*.json
*-credentials.json
*-service-account.json

# ---------------------------------------------------------------------------
# Docker
# ---------------------------------------------------------------------------
docker-compose.override.yml
.docker/

# ---------------------------------------------------------------------------
# Logs
# ---------------------------------------------------------------------------
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# ---------------------------------------------------------------------------
# Dependency directories (belt-and-suspenders — covered per-project too)
# ---------------------------------------------------------------------------
node_modules/

# ---------------------------------------------------------------------------
# OS artefacts
# ---------------------------------------------------------------------------
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# ---------------------------------------------------------------------------
# IDEs
# ---------------------------------------------------------------------------
.idea/
.vscode/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
*.swp
*.swo

# ---------------------------------------------------------------------------
# Misc
# ---------------------------------------------------------------------------
*.tmp
*.temp
.cache/
